{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ES2017",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["@types/react", "@types/react-dom"]
  },
  "include": [
    "src/ui.tsx",
    "src/components/**/*.tsx",
    "src/lib/ui/**/*.ts",
    "src/lib/**/*.ts",
    "src/types.ts",
    "src/schemas.ts",
    "src/__tests__/**/*.ts"
  ]
}
