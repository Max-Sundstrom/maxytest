{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./dist-types/node",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
