# Maxytest — apps/web environment variables template
#
# Copy this to `apps/web/.env.local` (gitignored) and fill in real values from
# the Supabase Dashboard → Project Settings → API.
#
# Plan 01-02 / Task 1 hand-off:
#   1. Create a Supabase Cloud project at https://supabase.com/dashboard/new
#   2. Add redirect URLs in Authentication → URL Configuration:
#        http://localhost:5173/auth/callback
#        http://localhost:4173/auth/callback
#        (Plan 01-06 adds: https://*.maxytest.pages.dev/auth/callback)
#   3. Copy the three keys below into apps/web/.env.local
#   4. From repo root: pnpm dlx supabase link --project-ref <ref-from-dashboard>
#   5. From repo root: pnpm dlx supabase db push     (applies 00001_init.sql)
#   6. From repo root: pnpm gen-types                  (regens types.gen.ts)
#
# ---- Public (bundled into client) -------------------------------------------
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Server / test-only (NEVER imported by apps/web/src/**) -----------------
# Plan 01-06 adds an ESLint rule banning imports of SUPABASE_SERVICE_ROLE_KEY
# from apps/web/src/**. It is consumed only by `apps/web/tests/rls/setup.ts`
# (Vitest Node env) and any future Supabase Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
